---
import Base from '../layouts/Base.astro';
import { useTranslations } from '../i18n';

const t = useTranslations('es');

const features = [
  { icon: 'ph-magnifying-glass', title: t('features.verify.title'), desc: t('features.verify.desc') },
  { icon: 'ph-tag', title: t('features.organize.title'), desc: t('features.organize.desc') },
  { icon: 'ph-lock-simple', title: t('features.privacy.title'), desc: t('features.privacy.desc') },
  { icon: 'ph-share-network', title: t('features.share.title'), desc: t('features.share.desc') },
  { icon: 'ph-squares-four', title: t('features.widget.title'), desc: t('features.widget.desc') },
  { icon: 'ph-export', title: t('features.export.title'), desc: t('features.export.desc') },
];
---
<Base>
  <section class="mx-auto max-w-5xl px-4 py-20 text-center sm:py-28">
    <img src="/app-icon.svg" alt="Urlora" class="mx-auto h-24 w-24 rounded-[22px] shadow-lg shadow-[rgb(0_122_255/0.2)]" />
    <span class="mt-6 inline-block rounded-full border border-[rgb(0_122_255/0.2)] bg-[rgb(0_122_255/0.08)] px-3 py-1 text-xs font-semibold uppercase tracking-widest text-(--brand)">
      {t('hero.tagline')}
    </span>
    <h1 class="mt-6 text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
      {t('hero.title')}
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-(--muted) leading-relaxed">
      {t('hero.subtitle')}
    </p>
    <a
      href="#"
      class="mt-8 inline-flex items-center gap-2 rounded-xl bg-(--brand) px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-[rgb(0_122_255/0.25)] transition hover:bg-(--brand-dim) focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--brand)"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
      {t('hero.cta')}
    </a>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-20">
    <h2 class="mb-12 text-center text-3xl font-semibold tracking-tight sm:text-4xl">
      {t('features.title')}
    </h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map(f => (
        <div class="rounded-2xl border border-(--border) bg-(--surface) p-6 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md hover:border-[rgb(0_122_255/0.3)]">
          <i class={`${f.icon} text-2xl text-(--brand)`}></i>
          <h3 class="mt-3 text-lg font-semibold">{f.title}</h3>
          <p class="mt-2 text-sm text-(--muted) leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <script is:inline src="https://unpkg.com/@phosphor-icons/web@2.1.1"></script>
</Base>
